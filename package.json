{
  "name": "superconnector",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "deploy:all": "bash scripts/deploy.sh",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply superconnector --local",
    "db:migrate:remote": "wrangler d1 migrations apply superconnector --remote"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "hono": "^4.10.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250428.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.86.0"
  }
}
